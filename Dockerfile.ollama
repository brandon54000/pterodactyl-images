ARG OLLAMA_BASE_IMAGE=ollama/ollama:latest
FROM ${OLLAMA_BASE_IMAGE}

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        gawk \
        grep \
        procps \
        sed \
        tini \
    && rm -rf /var/lib/apt/lists/* \
    && if ! getent group container >/dev/null 2>&1; then groupadd --gid 1000 container; fi \
    && if ! id -u container >/dev/null 2>&1; then useradd --uid 1000 --gid 1000 --create-home --home-dir /home/container --shell /bin/bash container; fi

RUN <<'EOF'
cat > /entrypoint.sh <<'SCRIPT'
#!/bin/bash
set -e

cd /home/container

MODIFIED_STARTUP=$(eval echo "$(echo "${STARTUP}" | sed -e 's/{{/${/g' -e 's/}}/}/g')")
echo ":/home/container$ ${MODIFIED_STARTUP}"

exec /bin/bash -lc "${MODIFIED_STARTUP}"
SCRIPT

cat > /usr/local/bin/ptero-ollama-start <<'SCRIPT'
#!/bin/bash
set -euo pipefail

cd /home/container

mkdir -p "${OLLAMA_MODELS:-/home/container/.ollama/models}"

SERVER_PORT_VALUE="${SERVER_PORT:-11434}"
export OLLAMA_MODELS="${OLLAMA_MODELS:-/home/container/.ollama/models}"
export OLLAMA_HOST="${OLLAMA_HOST:-0.0.0.0:${SERVER_PORT_VALUE}}"

LOCAL_API_URL="http://127.0.0.1:${SERVER_PORT_VALUE}"
READY=0

cleanup() {
  if [ -n "${OLLAMA_PID:-}" ] && kill -0 "${OLLAMA_PID}" 2>/dev/null; then
    kill "${OLLAMA_PID}" 2>/dev/null || true
    wait "${OLLAMA_PID}" 2>/dev/null || true
  fi
}

trap cleanup TERM INT

ollama serve &
OLLAMA_PID=$!

for _ in $(seq 1 120); do
  if curl -sf "${LOCAL_API_URL}/api/tags" >/dev/null; then
    READY=1
    break
  fi
  sleep 1
done

if [ "${READY}" -ne 1 ]; then
  echo "[ollama-start] Ollama n'a pas expose son API a temps sur ${LOCAL_API_URL}."
  exit 1
fi

if [ -n "${OLLAMA_AUTO_PULL_MODELS:-}" ]; then
  EXISTING_MODELS="$(ollama ls 2>/dev/null | awk 'NR > 1 { print $1 }' || true)"
  IFS=',' read -r -a REQUESTED_MODELS <<< "${OLLAMA_AUTO_PULL_MODELS}"

  for raw_model in "${REQUESTED_MODELS[@]}"; do
    model="$(printf '%s' "${raw_model}" | xargs)"
    if [ -z "${model}" ]; then
      continue
    fi

    if printf '%s\n' "${EXISTING_MODELS}" | grep -Fxq "${model}"; then
      echo "[ollama-start] Modele deja present: ${model}"
      continue
    fi

    echo "[ollama-start] Telechargement du modele ${model}"
    ollama pull "${model}"
  done
fi

echo "[ollama-start] Ollama pret sur ${OLLAMA_HOST}"
wait "${OLLAMA_PID}"
SCRIPT

chmod +x /entrypoint.sh /usr/local/bin/ptero-ollama-start
mkdir -p /home/container/.ollama/models
chown -R container:container /home/container
EOF

USER container
ENV USER=container HOME=/home/container OLLAMA_MODELS=/home/container/.ollama/models
WORKDIR /home/container

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
