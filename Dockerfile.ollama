ARG OLLAMA_BASE_IMAGE=ollama/ollama:v0.21.0
FROM ${OLLAMA_BASE_IMAGE}

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        gawk \
        grep \
        procps \
        sed \
        tini \
    && rm -rf /var/lib/apt/lists/*

RUN set -eux; \
    if getent group 1000 >/dev/null 2>&1; then \
      existing_group="$(getent group 1000 | cut -d: -f1)"; \
      if [ "${existing_group}" != "container" ]; then \
        groupmod -n container "${existing_group}"; \
      fi; \
    elif ! getent group container >/dev/null 2>&1; then \
      groupadd --gid 1000 container; \
    fi; \
    if getent passwd 1000 >/dev/null 2>&1; then \
      existing_user="$(getent passwd 1000 | cut -d: -f1)"; \
      if [ "${existing_user}" != "container" ]; then \
        usermod -l container -d /home/container -m "${existing_user}"; \
      fi; \
    elif ! id -u container >/dev/null 2>&1; then \
      useradd --uid 1000 --gid container --create-home --home-dir /home/container --shell /bin/bash container; \
    fi; \
    mkdir -p /home/container; \
    chown -R container:container /home/container

RUN <<'EOF'
cat > /entrypoint.sh <<'SCRIPT'
#!/bin/bash
set -e

cd /home/container

MODIFIED_STARTUP=$(eval echo "$(echo "${STARTUP}" | sed -e 's/{{/${/g' -e 's/}}/}/g')")
echo ":/home/container$ ${MODIFIED_STARTUP}"

exec /bin/bash -lc "${MODIFIED_STARTUP}"
SCRIPT

cat > /usr/local/bin/ptero-ollama-start <<'SCRIPT'
#!/bin/bash
set -euo pipefail

cd /home/container

mkdir -p "${OLLAMA_MODELS:-/home/container/.ollama/models}"

SERVER_PORT_VALUE="${SERVER_PORT:-11434}"
export OLLAMA_MODELS="${OLLAMA_MODELS:-/home/container/.ollama/models}"
export OLLAMA_HOST="${OLLAMA_HOST:-0.0.0.0:${SERVER_PORT_VALUE}}"
export HOME="${HOME:-/home/container}"

LOCAL_API_URL="http://127.0.0.1:${SERVER_PORT_VALUE}"
READY=0

cleanup() {
  if [ -n "${OLLAMA_PID:-}" ] && kill -0 "${OLLAMA_PID}" 2>/dev/null; then
    kill "${OLLAMA_PID}" 2>/dev/null || true
    wait "${OLLAMA_PID}" 2>/dev/null || true
  fi
}

trap cleanup TERM INT

echo "[ollama-start] Demarrage d'Ollama sur ${OLLAMA_HOST}"
ollama serve &
OLLAMA_PID=$!

sleep 1
if ! kill -0 "${OLLAMA_PID}" 2>/dev/null; then
  echo "[ollama-start] Le processus Ollama s'est arrete juste apres le lancement."
  wait "${OLLAMA_PID}" || true
  exit 1
fi

echo "[ollama-start] Attente de l'API locale sur ${LOCAL_API_URL}"
for _ in $(seq 1 120); do
  if curl -sf "${LOCAL_API_URL}/api/tags" >/dev/null; then
    READY=1
    break
  fi
  sleep 1
done

if [ "${READY}" -ne 1 ]; then
  echo "[ollama-start] Ollama n'a pas expose son API a temps sur ${LOCAL_API_URL}."
  exit 1
fi

echo "OLLAMA_READY ${OLLAMA_HOST}"

if [ -n "${OLLAMA_AUTO_PULL_MODELS:-}" ]; then
  (
    sleep 2
    EXISTING_MODELS="$(ollama ls 2>/dev/null | awk 'NR > 1 { print $1 }' || true)"
    IFS=',' read -r -a REQUESTED_MODELS <<< "${OLLAMA_AUTO_PULL_MODELS}"

    for raw_model in "${REQUESTED_MODELS[@]}"; do
      model="$(printf '%s' "${raw_model}" | xargs)"
      if [ -z "${model}" ]; then
        continue
      fi

      if printf '%s\n' "${EXISTING_MODELS}" | grep -Fxq "${model}"; then
        echo "[ollama-start] Modele deja present: ${model}"
        continue
      fi

      echo "[ollama-start] Telechargement du modele ${model}"
      if ! ollama pull "${model}"; then
        echo "[ollama-start] Avertissement: impossible de telecharger ${model}, Ollama reste en ligne."
      fi
    done
  ) &
fi

echo "[ollama-start] Ollama pret sur ${OLLAMA_HOST}"
wait "${OLLAMA_PID}"
SCRIPT

chmod +x /entrypoint.sh /usr/local/bin/ptero-ollama-start
mkdir -p /home/container/.ollama/models
chown -R container:container /home/container
EOF

USER container
ENV USER=container HOME=/home/container OLLAMA_MODELS=/home/container/.ollama/models
WORKDIR /home/container

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
